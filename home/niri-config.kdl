// Niri config — managed declaratively via home-manager
// DMS desktop shell auto-starts via systemd user service
// DMS overrides (included at end) take precedence over base settings below.
input {
    keyboard {
        xkb {

        }
        numlock
    }
    touchpad {
        tap
        natural-scroll
        accel-profile "flat"
    }
    mouse {
        natural-scroll
        accel-profile "flat"
    }
}

layout {
    gaps 16
    focus-ring {
        width 4
    }
    default-column-width {
        proportion 0.5
    }
}
hotkey-overlay {

}
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"
binds {
    // Terminal
    Mod+T hotkey-overlay-title="Open Terminal" {
        spawn "kitty"
    }
    // App launcher (DMS spotlight)
    Mod+D hotkey-overlay-title="Launch Application" {
        spawn "dms" "ipc" "spotlight" "toggle"
    }
    // Close window
    Mod+Q hotkey-overlay-title="Close Window" {
        close-window
    }
    // Focus movement
    Mod+Left hotkey-overlay-title="Focus Column Left" {
        focus-column-left
    }
    Mod+Down hotkey-overlay-title="Focus Window Down" {
        focus-window-down
    }
    Mod+Up hotkey-overlay-title="Focus Window Up" {
        focus-window-up
    }
    Mod+Right hotkey-overlay-title="Focus Column Right" {
        focus-column-right
    }
    Mod+H hotkey-overlay-title="Focus Column Left" {
        focus-column-left
    }
    Mod+J hotkey-overlay-title="Focus Window Down" {
        focus-window-down
    }
    Mod+K hotkey-overlay-title="Focus Window Up" {
        focus-window-up
    }
    Mod+L hotkey-overlay-title="Focus Column Right" {
        focus-column-right
    }
    // Move windows within workspace
    Mod+Ctrl+Left hotkey-overlay-title="Move Column Left" {
        move-column-left
    }
    Mod+Ctrl+Down hotkey-overlay-title="Move Window Down" {
        move-window-down
    }
    Mod+Ctrl+Up hotkey-overlay-title="Move Window Up" {
        move-window-up
    }
    Mod+Ctrl+Right hotkey-overlay-title="Move Column Right" {
        move-column-right
    }
    Mod+Ctrl+H hotkey-overlay-title="Move Column Left" {
        move-column-left
    }
    Mod+Ctrl+J hotkey-overlay-title="Move Window Down" {
        move-window-down
    }
    Mod+Ctrl+K hotkey-overlay-title="Move Window Up" {
        move-window-up
    }
    Mod+Ctrl+L hotkey-overlay-title="Move Column Right" {
        move-column-right
    }
    // Switch preset column widths
    Mod+R hotkey-overlay-title="Next Column Width Preset" {
        switch-preset-column-width
    }
    Mod+Shift+R hotkey-overlay-title="Previous Column Width Preset" {
        switch-preset-column-width-back
    }
    // Resize window/column
    Mod+Shift+Right hotkey-overlay-title="Widen Column" {
        set-column-width "+5%"
    }
    Mod+Shift+Left hotkey-overlay-title="Narrow Column" {
        set-column-width "-5%"
    }
    Mod+Shift+Up hotkey-overlay-title="Increase Height" {
        set-window-height "+5%"
    }
    Mod+Shift+Down hotkey-overlay-title="Decrease Height" {
        set-window-height "-5%"
    }
    Mod+Shift+H hotkey-overlay-title="Narrow Column" {
        set-column-width "-5%"
    }
    Mod+Shift+J hotkey-overlay-title="Decrease Height" {
        set-window-height "-5%"
    }
    Mod+Shift+K hotkey-overlay-title="Increase Height" {
        set-window-height "+5%"
    }
    Mod+Shift+L hotkey-overlay-title="Widen Column" {
        set-column-width "+5%"
    }
    // Consume or expel window left/right
    Mod+Ctrl+Shift+Left hotkey-overlay-title="Expel Window Left" {
        consume-or-expel-window-left
    }
    Mod+Ctrl+Shift+Right hotkey-overlay-title="Expel Window Right" {
        consume-or-expel-window-right
    }
    Mod+Ctrl+Shift+H hotkey-overlay-title="Expel Window Left" {
        consume-or-expel-window-left
    }
    Mod+Ctrl+Shift+L hotkey-overlay-title="Expel Window Right" {
        consume-or-expel-window-right
    }
    Mod+BracketLeft hotkey-overlay-title="Expel Window Left" {
        consume-or-expel-window-left
    }
    Mod+BracketRight hotkey-overlay-title="Expel Window Right" {
        consume-or-expel-window-right
    }
    // Workspaces
    Mod+Page_Down hotkey-overlay-title="Next Workspace" {
        focus-workspace-down
    }
    Mod+Page_Up hotkey-overlay-title="Previous Workspace" {
        focus-workspace-up
    }
    Mod+Ctrl+Page_Down hotkey-overlay-title="Move to Next Workspace" {
        move-column-to-workspace-down
    }
    Mod+Ctrl+Page_Up hotkey-overlay-title="Move to Previous Workspace" {
        move-column-to-workspace-up
    }
    Mod+1 hotkey-overlay-title="Workspace 1" {
        focus-workspace 1
    }
    Mod+2 hotkey-overlay-title="Workspace 2" {
        focus-workspace 2
    }
    Mod+3 hotkey-overlay-title="Workspace 3" {
        focus-workspace 3
    }
    Mod+4 hotkey-overlay-title="Workspace 4" {
        focus-workspace 4
    }
    Mod+5 hotkey-overlay-title="Workspace 5" {
        focus-workspace 5
    }
    Mod+6 hotkey-overlay-title="Workspace 6" {
        focus-workspace 6
    }
    Mod+7 hotkey-overlay-title="Workspace 7" {
        focus-workspace 7
    }
    Mod+8 hotkey-overlay-title="Workspace 8" {
        focus-workspace 8
    }
    Mod+9 hotkey-overlay-title="Workspace 9" {
        focus-workspace 9
    }
    // Move column to workspace (numbered)
    Mod+Ctrl+1 hotkey-overlay-title="Move to Workspace 1" {
        move-column-to-workspace 1
    }
    Mod+Ctrl+2 hotkey-overlay-title="Move to Workspace 2" {
        move-column-to-workspace 2
    }
    Mod+Ctrl+3 hotkey-overlay-title="Move to Workspace 3" {
        move-column-to-workspace 3
    }
    Mod+Ctrl+4 hotkey-overlay-title="Move to Workspace 4" {
        move-column-to-workspace 4
    }
    Mod+Ctrl+5 hotkey-overlay-title="Move to Workspace 5" {
        move-column-to-workspace 5
    }
    Mod+Ctrl+6 hotkey-overlay-title="Move to Workspace 6" {
        move-column-to-workspace 6
    }
    Mod+Ctrl+7 hotkey-overlay-title="Move to Workspace 7" {
        move-column-to-workspace 7
    }
    Mod+Ctrl+8 hotkey-overlay-title="Move to Workspace 8" {
        move-column-to-workspace 8
    }
    Mod+Ctrl+9 hotkey-overlay-title="Move to Workspace 9" {
        move-column-to-workspace 9
    }
    // Fullscreen / maximize
    Mod+F hotkey-overlay-title="Maximize Column" {
        maximize-column
    }
    Mod+Shift+F hotkey-overlay-title="Fullscreen Window" {
        fullscreen-window
    }
    // Center window
    Mod+C hotkey-overlay-title="Center Window" {
        center-window
    }
    // Floating
    Mod+V hotkey-overlay-title="Toggle Floating" {
        toggle-window-floating
    }
    Mod+Shift+V hotkey-overlay-title="Switch Floating / Tiling Focus" {
        switch-focus-between-floating-and-tiling
    }
    // Power
    Mod+Alt+Shift+H hotkey-overlay-title="Hibernate" {
        spawn "systemctl" "hibernate"
    }
    Mod+Alt+Shift+S hotkey-overlay-title="Suspend" {
        spawn "systemctl" "suspend"
    }
    Mod+Alt+Shift+P hotkey-overlay-title="Power Off" {
        spawn "systemctl" "poweroff"
    }
    Mod+Alt+Shift+L hotkey-overlay-title="Lock Screen" {
        spawn "swaylock"
    }
    // Quit
    Mod+Shift+E hotkey-overlay-title="Quit Niri" {
        quit
    }
    Ctrl+Alt+Delete hotkey-overlay-title="Quit Niri" {
        quit
    }
    // Screenshots
    Print hotkey-overlay-title="Screenshot Area" {
        screenshot
    }
    Ctrl+Print hotkey-overlay-title="Screenshot Screen" {
        screenshot-screen
    }
    // Volume keys
    XF86AudioRaiseVolume hotkey-overlay-title="Volume Up" {
        spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1+ -l 1.0"
    }
    XF86AudioLowerVolume hotkey-overlay-title="Volume Down" {
        spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1-"
    }
    XF86AudioMute hotkey-overlay-title="Mute Toggle" {
        spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    }
    // Playback keys
    XF86AudioPrev hotkey-overlay-title="Previous Track" {
        spawn-sh "playerctl previous"
    }
    XF86AudioPlay hotkey-overlay-title="Play / Pause" {
        spawn-sh "playerctl play-pause"
    }
    XF86AudioNext hotkey-overlay-title="Next Track" {
        spawn-sh "playerctl next"
    }
    // Brightness keys
    XF86MonBrightnessUp hotkey-overlay-title="Brightness Up" {
        spawn "brightnessctl" "--class=backlight" "set" "+10%"
    }
    XF86MonBrightnessDown hotkey-overlay-title="Brightness Down" {
        spawn "brightnessctl" "--class=backlight" "set" "10%-"
    }
    // Overview
    Mod+O hotkey-overlay-title="Toggle Overview" {
        toggle-overview
    }
    // Help
    Mod+Shift+Slash hotkey-overlay-title="Show Hotkeys" {
        show-hotkey-overlay
    }
}

// ── DMS runtime overrides (included last → take precedence) ──
include "dms/colors.kdl"
include "dms/layout.kdl"
include "dms/alttab.kdl"
include "dms/wpblur.kdl"
include "dms/cursor.kdl"

